{
  "name": "@dangbt/pro-ui",
  "version": "1.0.22",
  "type": "module",
  "description": "React UI component library built on React Aria Components + Tailwind CSS v4",
  "keywords": [
    "react",
    "ui",
    "components",
    "tailwind",
    "react-aria"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/dangbt/pro-ui.git"
  },
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/components/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./tailwind.css": "./tailwind.css",
    "./theme.css": "./theme.css"
  },
  "files": [
    "dist",
    "src",
    "tailwind.css",
    "theme.css"
  ],
  "sideEffects": false,
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:lib": "vite build -c vite.lib.config.ts && tsc -p tsconfig.lib.json",
    "prepublishOnly": "pnpm build:lib",
    "preview": "vite preview"
  },
  "peerDependencies": {
    "@hookform/resolvers": ">=3",
    "@internationalized/date": ">=3",
    "@tanstack/react-table": ">=8",
    "lucide-react": ">=0.400.0",
    "react": ">=18",
    "react-aria-components": ">=1",
    "react-dom": ">=18",
    "react-hook-form": ">=7",
    "tailwindcss": ">=4",
    "zod": ">=3"
  },
  "dependencies": {
    "clsx": "2.1.1",
    "tailwind-merge": "2.6.1",
    "tailwindcss-react-aria-components": "2.1.0"
  },
  "devDependencies": {
    "@hookform/resolvers": "5.4.0",
    "@internationalized/date": "3.12.1",
    "@tailwindcss/vite": "4.3.0",
    "@tanstack/react-table": "8.21.3",
    "@types/node": "^25.9.1",
    "@types/react": "18.3.29",
    "@types/react-dom": "18.3.7",
    "@vitejs/plugin-react": "4.7.0",
    "lucide-react": "1.16.0",
    "playwright": "1.60.0",
    "react": "18.3.1",
    "react-aria-components": "1.17.0",
    "react-dom": "18.3.1",
    "react-hook-form": "7.76.1",
    "tailwindcss": "4.3.0",
    "typescript": "5.9.3",
    "vite": "6.4.2",
    "vite-plugin-dts": "5.0.1",
    "zod": "4.4.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
